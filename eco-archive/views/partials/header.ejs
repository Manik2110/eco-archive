<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8"/>
  <meta name="viewport" content="width=device-width, initial-scale=1.0"/>
  <title>Eco Archive</title>
  <link rel="stylesheet" href="/css/style.css"/>
</head>
<body>
<nav>
  <a href="/" class="nav-brand">🌿 Eco Archive</a>
  <div class="nav-links">
    <a href="/resources/browse">Browse</a>
