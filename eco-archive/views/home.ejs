<%- include('partials/header') %>

<div class="eco-banner">
  🌍 This site is designed to save energy — dark mode by default, no heavy images, no autoplay videos, minimal CSS. Every byte counts.
</div>

<section class="hero">
  <h1>🌿 Eco Archive</h1>
  <p>A sustainable digital library where students share text-based study notes.<br/>Lightweight by design. Green by purpose.</p>
  <a href="/resources/browse" class="btn btn-green">Browse Resources</a>
  &nbsp;
  <% if (!user) { %>
    <a href="/auth/register" class="btn btn-outline">Join Free</a>
  <% } else { %>
    <a href="/resources/upload" class="btn btn-outline">Upload Notes</a>
  <% } %>
</section>

<section class="section">
  <div class="grid-stats">
    <div class="card center">
      <div class="stat-num"><%= stats.totalResources %></div>
      <div class="stat-label">Resources</div>
    </div>
    <div class="card center">
      <div class="stat-num"><%= stats.totalUsers %></div>
      <div class="stat-label">Members</div>
    </div>
    <div class="card center">
      <div class="stat-num"><%= stats.totalSubjects %></div>
      <div class="stat-label">Subjects</div>
    </div>
  </div>
</section>

<section class="section">
  <h2>Browse by Subject</h2>
  <div class="tags-row">
    <% if (subjects.length === 0) { %>
      <span class="muted">No subjects yet — be the first to upload!</span>
    <% } %>
    <% subjects.forEach(s => { %>
      <a href="/resources/browse?subject=<%= s.subject %>" class="tag"><%= s.subject %></a>
    <% }) %>
  </div>
</section>

<section class="section">
  <h2>Recent Uploads</h2>
  <% if (recent.length === 0) { %>
    <p class="muted">No resources yet. <a href="/resources/upload">Upload the first one!</a></p>
  <% } else { %>
    <div class="grid-3">
      <% recent.forEach(r => { %>
        <div class="card flex flex-col gap-sm">
          <strong><%= r.title %></strong>
          <span class="muted"><%= r.subject %> · <%= r.file_type %></span>
          <a href="/resources/download/<%= r.id %>" class="btn btn-outline btn-sm" style="margin-top:auto">⬇ Download</a>
        </div>
      <% }) %>
    </div>
  <% } %>
</section>

<section class="section eco-banner">
  💡 <strong>Why Eco Archive?</strong> Traditional websites waste energy with heavy frameworks, autoplay videos, and bloated CSS.
  We use dark mode (saves OLED power), system fonts (no font downloads), and hand-written CSS under 5KB.
</section>

<%- include('partials/footer') %>
